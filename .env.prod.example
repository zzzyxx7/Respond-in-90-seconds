A23_MODEL_TYPE=deepseek
A23_DEEPSEEK_BASE_URL=https://api.deepseek.com
A23_DEEPSEEK_API_KEY=sk-your-api-key
A23_DEEPSEEK_MODEL=deepseek-chat

