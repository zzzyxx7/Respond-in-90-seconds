<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.fusion.docfusion.mapper.FillTaskMapper">

    <resultMap id="FillTaskResultMap" type="com.fusion.docfusion.entity.FillTask">
        <id property="id" column="id"/>
        <result property="documentSetId" column="document_set_id"/>
        <result property="templateId" column="template_id"/>
        <result property="status" column="status"/>
        <result property="resultFilePath" column="result_file_path"/>
        <result property="createdAt" column="created_at"/>
        <result property="finishedAt" column="finished_at"/>
        <result property="errorMessage" column="error_message"/>
    </resultMap>

    <insert id="insert" parameterType="com.fusion.docfusion.entity.FillTask"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO fill_task (document_set_id, template_id, status, result_file_path, created_at, finished_at, error_message)
        VALUES (#{documentSetId}, #{templateId}, #{status}, #{resultFilePath}, #{createdAt}, #{finishedAt}, #{errorMessage})
    </insert>

    <update id="updateById" parameterType="com.fusion.docfusion.entity.FillTask">
        UPDATE fill_task
        <set>
            <if test="status != null">status = #{status},</if>
            <if test="resultFilePath != null">result_file_path = #{resultFilePath},</if>
            <if test="finishedAt != null">finished_at = #{finishedAt},</if>
            <if test="errorMessage != null">error_message = #{errorMessage},</if>
        </set>
        WHERE id = #{id}
    </update>

    <select id="selectById" resultMap="FillTaskResultMap">
        SELECT * FROM fill_task WHERE id = #{id}
    </select>
</mapper>
