<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.fusion.docfusion.mapper.FillTaskStepMapper">

    <resultMap id="FillTaskStepResultMap" type="com.fusion.docfusion.entity.FillTaskStep">
        <id property="id" column="id"/>
        <result property="taskId" column="task_id"/>
        <result property="stepCode" column="step_code"/>
        <result property="stepName" column="step_name"/>
        <result property="status" column="status"/>
        <result property="startedAt" column="started_at"/>
        <result property="finishedAt" column="finished_at"/>
        <result property="durationMs" column="duration_ms"/>
        <result property="message" column="message"/>
        <result property="errorMessage" column="error_message"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!--
      依赖唯一键：uk_fill_task_step_task_step (task_id, step_code)
      这样可以用 upsert 覆盖更新步骤状态/耗时/错误等
    -->
    <insert id="upsert" parameterType="com.fusion.docfusion.entity.FillTaskStep">
        INSERT INTO fill_task_step
        (task_id, step_code, step_name, status,
         started_at, finished_at, duration_ms,
         message, error_message,
         created_at, updated_at)
        VALUES
        (#{taskId}, #{stepCode}, #{stepName}, #{status},
         #{startedAt}, #{finishedAt}, #{durationMs},
         #{message}, #{errorMessage},
         NOW(), NOW())
        ON DUPLICATE KEY UPDATE
            step_name = VALUES(step_name),
            status = VALUES(status),
            started_at = VALUES(started_at),
            finished_at = VALUES(finished_at),
            duration_ms = VALUES(duration_ms),
            message = VALUES(message),
            error_message = VALUES(error_message),
            updated_at = NOW()
    </insert>

    <select id="selectByTaskId" resultMap="FillTaskStepResultMap">
        SELECT *
        FROM fill_task_step
        WHERE task_id = #{taskId}
        ORDER BY id ASC
    </select>

    <delete id="deleteByTaskId">
        DELETE FROM fill_task_step WHERE task_id = #{taskId}
    </delete>

</mapper>

