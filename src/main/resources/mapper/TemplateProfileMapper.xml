<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.fusion.docfusion.mapper.TemplateProfileMapper">

    <resultMap id="TemplateProfileResultMap" type="com.fusion.docfusion.entity.TemplateProfile">
        <id property="id" column="id"/>
        <result property="templateId" column="template_id"/>
        <result property="content" column="content"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.fusion.docfusion.entity.TemplateProfile"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO template_profile (template_id, content, created_at, updated_at)
        VALUES (#{templateId}, #{content}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="update" parameterType="com.fusion.docfusion.entity.TemplateProfile">
        UPDATE template_profile
        SET content    = #{content},
            updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <select id="selectByTemplateId" resultMap="TemplateProfileResultMap">
        SELECT *
        FROM template_profile
        WHERE template_id = #{templateId}
        ORDER BY created_at DESC
        LIMIT 1
    </select>
</mapper>

